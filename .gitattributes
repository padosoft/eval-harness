* text=auto eol=lf

# PHP source — always LF.
*.php text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.neon text eol=lf
*.xml text eol=lf
*.sh text eol=lf

# Composer lockfile is excluded from VCS but ensure LF if ever added.
composer.lock text eol=lf

# Export-ignore for slim release tarballs.
.github/        export-ignore
tests/          export-ignore
resources/      export-ignore
.editorconfig   export-ignore
.gitattributes  export-ignore
.gitignore      export-ignore
phpunit.xml     export-ignore
phpstan.neon.dist export-ignore
pint.json       export-ignore
