{
    "name": "padosoft/eval-harness",
    "description": "Agentic eval framework for Laravel: golden datasets, LLM-as-judge, adversarial harness, regression detection",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": ["laravel", "ai", "eval", "agentic", "regression", "golden-dataset", "adversarial"],
    "authors": [
        {
            "name": "Lorenzo Padovani",
            "email": "lorenzo.padovani@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lopadova\\EvalHarness\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lopadova\\EvalHarness\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lopadova\\EvalHarness\\EvalHarnessServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
